# Gemini API key for the LLM Model (Required if using Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API key for the LLM Model (Required if using DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tavily API key for Web Research (Optional, enables the "Online Connection" toggle)
TAVILY_API_KEY=your_tavily_api_key_here
